              5
            </span>
          </li>
          <li
            class="degree-chip-item"
            data-in-scale="true"
          >
            <button
              aria-label="Hide A"
              aria-pressed="false"
              class="degree-chip"
              type="button"
            >
              <span
                class="degree-chip-note"
              >
                A
              </span>
            </button>
            <span
              class="degree-chip-interval"
            >
              6
            </span>
          </li>
          <li
            class="degree-chip-item"
            data-in-scale="true"
          >
            <button
              aria-label="Hide B"
              aria-pressed="false"
              class="degree-chip"
              type="button"
            >
              <span
                class="degree-chip-note"
              >
                B
              </span>
            </button>
            <span
              class="degree-chip-interval"
            >
              7
            </span>
          </li>
        </ul>
      </section>
    </div>
