                class="section-label"
              >
                Fret Range
              </span>
              <div
                class="fret-range-control dashboard"
              >
                <div
                  class="fret-group fret-start"
                >
                  <span
                    class="fret-label"
                  >
                    Start
                  </span>
                  <button
                    aria-label="Decrease start fret (0)"
                    class="fret-btn"
                    disabled=""
                    type="button"
                  >
                    −
                  </button>
                  <span
                    class="fret-value"
                  >
                    0
                  </span>
                  <button
                    aria-label="Increase start fret (0)"
                    class="fret-btn"
                    type="button"
                  >
                    +
                  </button>
                </div>
                <span
                  class="range-separator"
                >
                  —
                </span>
                <div
                  class="fret-group fret-end"
                >
                  <span
                    class="fret-label"
                  >
                    End
                  </span>
                  <button
                    aria-label="Decrease end fret (25)"
                    class="fret-btn"
                    type="button"
                  >
