    <div
      class="controls-panel controls-panel--dashboard"
      data-mode="stacked"
    >
      <section
        aria-labelledby="_r_26_"
        class="card dashboard-card dashboard-card--configuration"
      >
        <div
          class="card-header"
        >
          <div
            class="card-header-title-row"
          >
            <h2
              class="card-header-title"
              id="_r_26_"
            >
              Configuration
            </h2>
          </div>
        </div>
        <div
          class="card-body"
        >
          <div
            class="control-group"
          >
            <div
              class="control-section"
            >
              <span
                class="section-label"
              >
                Fingering Pattern
              </span>
              <div
                class="toggle-group toggle-group--default"
                role="group"
              >
                <button
                  aria-pressed="true"
                  class="toggle-btn active"
                  type="button"
                >
                  All
                </button>
                <button
                  aria-pressed="false"
                  class="toggle-btn"
                  type="button"
                >
                  CAGED
                </button>
                <button
                  aria-pressed="false"
                  class="toggle-btn"
                  type="button"
                >
                  3NPS
                </button>
              </div>
            </div>
            <div
              class="control-section"
            >
              <span
                class="section-label"
              >
                Note Labels
              </span>
              <div
                class="toggle-group toggle-group--default"
                role="group"
              >
                <button
                  aria-pressed="true"
                  class="toggle-btn active"
                  type="button"
                >
                  Notes
                </button>
                <button
                  aria-pressed="false"
                  class="toggle-btn"
                  type="button"
                >
                  Intervals
                </button>
                <button
                  aria-pressed="false"
                  class="toggle-btn"
                  type="button"
                >
                  None
                </button>
              </div>
            </div>
            <div
              class="control-section"
            >
              <span
                class="section-label"
              >
                Fret Range
              </span>
              <div
                class="fret-range-control dashboard"
              >
                <div
                  class="fret-group fret-start"
                >
                  <span
                    class="fret-label"
                  >
                    Start
                  </span>
                  <button
                    aria-label="Decrease start fret (0)"
                    class="fret-btn"
                    disabled=""
                    type="button"
                  >
                    −
                  </button>
                  <span
                    class="fret-value"
                  >
                    0
                  </span>
                  <button
                    aria-label="Increase start fret (0)"
                    class="fret-btn"
                    type="button"
                  >
                    +
                  </button>
                </div>
                <span
                  class="range-separator"
                >
                  —
                </span>
                <div
