                  class="toggle-btn active"
                  type="button"
                >
                  Notes
                </button>
                <button
                  aria-pressed="false"
                  class="toggle-btn"
                  type="button"
                >
                  Intervals
                </button>
                <button
                  aria-pressed="false"
                  class="toggle-btn"
                  type="button"
                >
                  None
                </button>
              </div>
            </div>
            <div
              class="control-section"
            >
