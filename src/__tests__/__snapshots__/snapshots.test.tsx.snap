exports[`Component Snapshots > App layout snapshots > renders desktop-split layout snapshot (1920×1200) > app-desktop-split-default 1`] = `
<div>
  <div
    class="app-container"
    data-full-width-overlay="false"
    data-header-actions="default"
    data-header-subtitle="visible"
    data-layout-tier="desktop"
    data-layout-variant="desktop-split"
  >
    <header
      class="app-header"
      role="banner"
    >
      <div
        class="app-header-brand"
      >
        <span
          aria-hidden="true"
          class="app-header-brand-icon"
        >
          <svg
            aria-hidden="true"
            class="lucide lucide-music icon"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M9 18V5l12-2v13"
            />
            <circle
              cx="6"
              cy="18"
              r="3"
            />
            <circle
              cx="18"
              cy="16"
              r="3"
            />
          </svg>
        </span>
        <div
          class="app-header-brand-text"
        >
          <span
            class="app-header-brand-title"
          >
            FretFlow
          </span>
          <span
            class="app-header-brand-subtitle"
          >
            Interactive Fretboard & Music Theory
          </span>
        </div>
      </div>
      <div
        class="app-header-actions"
      >
        <a
          class="kofi-header-btn"
          href="https://ko-fi.com/E1E01XFJ0G"
          rel="noopener noreferrer"
          target="_blank"
          title="Support FretFlow on Ko-fi"
        >
          <img
            alt="Support me on Ko-fi"
            class="kofi-btn-desktop"
            src="/fretboard-app/support_me_on_kofi_blue.png"
          />
          <img
            alt="Ko-fi"
            class="kofi-btn-mobile"
            src="/fretboard-app/kofi_symbol.png"
          />
        </a>
        <button
          aria-label="Open settings"
          class="header-btn"
          title="Settings"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide lucide-settings2 lucide-settings-2 icon"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M14 17H5"
            />
            <path
              d="M19 7h-9"
            />
            <circle
              cx="17"
              cy="17"
              r="3"
            />
            <circle
              cx="7"
              cy="7"
              r="3"
            />
          </svg>
        </button>
        <button
          aria-label="Mute audio"
          class="header-btn"
          title="Mute"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide lucide-volume2 lucide-volume-2 icon icon-active"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M11 4.702a.705.705 0 0 0-1.203-.498L6.413 7.587A1.4 1.4 0 0 1 5.416 8H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h2.416a1.4 1.4 0 0 1 .997.413l3.383 3.384A.705.705 0 0 0 11 19.298z"
            />
            <path
              d="M16 9a5 5 0 0 1 0 6"
            />
            <path
              d="M19.364 18.364a9 9 0 0 0 0-12.728"
            />
          </svg>
        </button>
        <button
          aria-label="Open help"
          class="header-btn"
          title="Help & Instructions"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide lucide-circle-question-mark icon"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle
              cx="12"
              cy="12"
              r="10"
            />
            <path
              d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"
            />
            <path
              d="M12 17h.01"
            />
          </svg>
        </button>
      </div>
    </header>
    <main
      class="main-fretboard"
    >
      <div
        class="fretboard-outer"
      >
        <div
          class="fretboard-toolbar"
        >
          <div
            class="viewport-jumps"
          >
            <span
              class="section-label"
            >
              Go to
            </span>
            <button
              class="toolbar-btn"
            >
              Open
            </button>
            <button
              class="toolbar-btn"
            >
              Mid
            </button>
            <button
              class="toolbar-btn"
            >
              High
            </button>
          </div>
        </div>
        <div
          class="fretboard-wrapper hide-scrollbar"
          style="cursor: default;"
        >
          <div
            aria-label="Guitar fretboard — C Major scale"
            class="fretboard-board"
            role="group"
          >
            <div
              class="fretboard-neck"
              style="height: 296px; width: 1383px; --string-row-px: 48px;"
            >
              <svg
                aria-hidden="true"
                class="fretboard-main-svg"
                height="288"
                style="display: block; position: absolute; top: 4px; left: 4px;"
                width="1375"
              >
                <defs>
                  <lineargradient
                    id="fretboard-wood"
                    x1="0"
                    x2="0"
                    y1="0"
                    y2="1"
                  >
                    <stop
                      offset="0%"
                      stop-color="var(--fretboard-wood-top)"
                    />
                    <stop
                      offset="100%"
                      stop-color="var(--fretboard-wood-bottom)"
                    />
                  </lineargradient>
                  <filter
                    height="200%"
                    id="glow-cyan"
                    width="200%"
                    x="-50%"
                    y="-50%"
                  >
                    <fedropshadow
                      dx="0"
                      dy="0"
                      flood-color="#4DE4FF"
                      flood-opacity="0.65"
                      stdDeviation="3"
                    />
                  </filter>
