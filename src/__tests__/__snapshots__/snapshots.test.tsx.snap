                  </button>
                  <span
                    class="fret-value"
                  >
                    25
                  </span>
                  <button
                    aria-label="Increase end fret (25)"
                    class="fret-btn"
                    disabled=""
                    type="button"
                  >
                    +
                  </button>
                </div>
