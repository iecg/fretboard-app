exports[`Component Snapshots > Fretboard snapshots > renders with degree display format snapshot > fretboard-degree-display 1`] = `
<div>
  <div
    class="fretboard-outer"
  >
    <div
      class="fretboard-toolbar"
    >
      <div
        class="viewport-jumps"
      >
        <span
          class="section-label"
        >
          Go to
        </span>
        <button
          class="toolbar-btn"
        >
          Open
        </button>
        <button
          class="toolbar-btn"
        >
          Mid
        </button>
        <button
          class="toolbar-btn"
        >
          High
        </button>
      </div>
    </div>
    <div
      class="fretboard-wrapper hide-scrollbar"
      style="cursor: default;"
    >
      <div
        aria-label="Guitar fretboard — G Major scale"
        class="fretboard-board"
        role="group"
      >
        <div
          class="fretboard-neck"
          style="height: 248px; width: 1233px; --string-row-px: 40px;"
        >
          <svg
            aria-hidden="true"
            class="fretboard-main-svg"
            height="240"
            style="display: block; position: absolute; top: 4px; left: 4px;"
            width="1225"
          >
            <defs>
              <lineargradient
                id="fretboard-wood"
                x1="0"
                x2="0"
                y1="0"
                y2="1"
              >
                <stop
                  offset="0%"
                  stop-color="var(--fretboard-wood-top)"
                />
                <stop
                  offset="100%"
                  stop-color="var(--fretboard-wood-bottom)"
                />
              </lineargradient>
              <filter
                height="200%"
                id="glow-cyan"
                width="200%"
                x="-50%"
                y="-50%"
              >
                <fedropshadow
                  dx="0"
                  dy="0"
                  flood-color="#4DE4FF"
                  flood-opacity="0.65"
                  stdDeviation="3"
                />
              </filter>
              <filter
                height="200%"
                id="glow-orange"
                width="200%"
                x="-50%"
                y="-50%"
              >
                <fedropshadow
                  dx="0"
                  dy="0"
                  flood-color="#FF9A4D"
                  flood-opacity="0.65"
                  stdDeviation="3"
                />
              </filter>
            </defs>
            <rect
              fill="url(#fretboard-wood)"
              height="240"
              width="1225"
              x="0"
              y="0"
            />
            <rect
