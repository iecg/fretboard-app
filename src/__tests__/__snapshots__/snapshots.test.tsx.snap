                  stop-color="#3e444c"
                />
              </lineargradient>
              <radialgradient
                cx="35%"
                cy="32%"
                id="fretboard-_r_2e_-inlay-pearl"
                r="75%"
              >
                <stop
                  offset="0%"
                  stop-color="rgb(250 247 232)"
                  stop-opacity="0.98"
