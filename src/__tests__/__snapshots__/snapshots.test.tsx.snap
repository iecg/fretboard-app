                id="fretboard-_r_2_-string-shadow-blur"
                width="1233"
                x="-4"
                y="-4"
              >
                <fegaussianblur
                  stdDeviation="0.75"
                />
              </filter>
              <lineargradient
                id="fretboard-_r_2_-nut-material"
                x1="0"
                x2="0"
                y1="0"
                y2="1"
              >
                <stop
