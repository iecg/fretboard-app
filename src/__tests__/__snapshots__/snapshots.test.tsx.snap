            </button>
          </div>
        </div>
        <div
          class="fretboard-wrapper hide-scrollbar"
          style="cursor: default;"
        >
          <div
            aria-label="Guitar fretboard — C Major scale"
            role="img"
          >
            <div
              class="fret-numbers-row"
              style="width: 1383px; padding-left: 4px;"
            >
              <span
                class="fret-number"
