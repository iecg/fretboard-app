exports[`Component Snapshots > Fretboard snapshots > renders with CAGED shapes at small mobile spacing (stringRowPx=32) > fretboard-caged-small-mobile-32px 1`] = `
<div>
  <div
    class="fretboard-outer"
    data-testid="fretboard-main"
  >
    <div
      class="fretboard-wrapper hide-scrollbar"
      style="cursor: default;"
    >
      <div
        aria-label="Guitar fretboard — E"
        class="fretboard-board"
        role="group"
      >
        <div
          class="fretboard-neck"
          style="height: 192px; width: 1225px; --string-row-px: 32px; --glow-cyan: url(#fretboard-_r_b_-glow-cyan); --glow-orange: url(#fretboard-_r_b_-glow-orange); --glow-violet: url(#fretboard-_r_b_-glow-violet);"
        >
          <svg
            aria-hidden="true"
            class="fretboard-main-svg"
            height="192"
            style="display: block; position: absolute; top: 0px; left: 0px;"
            width="1225"
          >
            <defs>
              <lineargradient
                id="fretboard-_r_b_-fretboard-wood"
