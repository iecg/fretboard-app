                  stop-color="rgb(0 0 0 / 0.55)"
                />
              </lineargradient>
              <filter
                height="100%"
                id="fretboard-_r_0_-wood-grain-filter"
                width="100%"
                x="0%"
                y="0%"
              >
                <feturbulence
                  baseFrequency="0.012 0.95"
                  numOctaves="4"
                  result="grain"
                  seed="3"
                  type="fractalNoise"
                />
                <fecolormatrix
                  in="grain"
