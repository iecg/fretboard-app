exports[`Component Snapshots > App layout snapshots > renders mobile layout snapshot > app-mobile-default 1`] = `
<div>
  <div
    class="app-container"
    data-full-width-overlay="true"
    data-header-actions="compact"
    data-header-subtitle="hidden"
    data-layout-tier="mobile"
    data-layout-variant="mobile"
  >
    <header
      class="app-header"
      role="banner"
    >
      <div
        class="app-header-brand"
      >
        <span
          aria-hidden="true"
          class="app-header-brand-icon"
        >
          <svg
            aria-hidden="true"
            class="brand-mark"
            style="overflow: visible;"
            viewBox="0 0 612.475 596.26327"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <filter
                height="140%"
                id="brand-mark-glow-cyan"
                width="140%"
                x="-20%"
                y="-20%"
              >
                <fedropshadow
                  dx="0"
                  dy="0"
                  flood-color="#4DE4FF"
                  flood-opacity="0.9"
                  stdDeviation="3"
                />
                <fedropshadow
                  dx="0"
                  dy="0"
                  flood-color="#4DE4FF"
                  flood-opacity="0.4"
                  stdDeviation="9"
                />
              </filter>
              <filter
                height="140%"
                id="brand-mark-glow-orange"
                width="140%"
                x="-20%"
                y="-20%"
              >
                <fedropshadow
                  dx="0"
                  dy="0"
                  flood-color="#FF9A4D"
                  flood-opacity="0.9"
                  stdDeviation="3"
                />
                <fedropshadow
                  dx="0"
                  dy="0"
                  flood-color="#FF9A4D"
                  flood-opacity="0.4"
                  stdDeviation="9"
                />
              </filter>
            </defs>
            <g
              transform="translate(-89.501209,0.00925)"
