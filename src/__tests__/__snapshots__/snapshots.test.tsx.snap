exports[`Component Snapshots > Fretboard snapshots > renders A Minor Pentatonic snapshot > fretboard-a-minor-pentatonic 1`] = `
<div>
  <div
    class="fretboard-outer"
    data-testid="fretboard-main"
  >
    <div
      class="fretboard-wrapper hide-scrollbar"
      style="cursor: default;"
    >
      <div
        aria-label="Guitar fretboard — A"
        class="fretboard-board"
        role="group"
      >
        <div
          class="fretboard-neck"
          style="height: 216px; width: 1225px; --string-row-px: 36px; --glow-cyan: url(#fretboard-_r_1_-glow-cyan); --glow-orange: url(#fretboard-_r_1_-glow-orange); --glow-violet: url(#fretboard-_r_1_-glow-violet);"
        >
          <svg
            aria-hidden="true"
            class="fretboard-main-svg"
            height="216"
            style="display: block; position: absolute; top: 0px; left: 0px;"
            width="1225"
          >
            <defs>
              <lineargradient
                id="fretboard-_r_1_-fretboard-wood"
                x1="0"
                x2="0"
                y1="0"
                y2="1"
              >
                <stop
                  offset="0%"
                  stop-color="var(--fretboard-wood-top)"
                />
                <stop
                  offset="55%"
                  stop-color="#0d0805"
                />
                <stop
                  offset="100%"
                  stop-color="var(--fretboard-wood-bottom)"
                />
              </lineargradient>
              <lineargradient
                id="fretboard-_r_1_-fretboard-vignette"
                x1="0"
                x2="1"
                y1="0"
                y2="0"
              >
                <stop
                  offset="0%"
                  stop-color="rgb(0 0 0 / 0.55)"
                />
                <stop
                  offset="8%"
                  stop-color="rgb(0 0 0 / 0.16)"
                />
                <stop
                  offset="50%"
                  stop-color="rgb(255 255 255 / 0)"
                />
                <stop
                  offset="92%"
                  stop-color="rgb(0 0 0 / 0.16)"
                />
                <stop
                  offset="100%"
                  stop-color="rgb(0 0 0 / 0.55)"
                />
              </lineargradient>
              <filter
                height="100%"
                id="fretboard-_r_1_-wood-grain-filter"
                width="100%"
                x="0%"
                y="0%"
              >
                <feturbulence
                  baseFrequency="0.012 0.95"
                  numOctaves="4"
                  result="grain"
                  seed="3"
                  type="fractalNoise"
                />
                <fecolormatrix
                  in="grain"
                  result="grainTinted"
                  type="matrix"
                  values="0 0 0 0 0.09
                        0 0 0 0 0.05
                        0 0 0 0 0.03
                        0 0 0 0.72 0"
                />
                <fecomposite
                  in="grainTinted"
                  in2="SourceGraphic"
                  operator="in"
                />
              </filter>
              <filter
                height="100%"
                id="fretboard-_r_1_-wood-highlights-filter"
                width="100%"
                x="0%"
                y="0%"
              >
                <feturbulence
                  baseFrequency="0.022 0.55"
                  numOctaves="2"
