          <div
            class="control-section"
          >
            <div
              class="labeled-select"
            >
              <label
                class="labeled-select-label"
                for="_r_m_"
              >
                <span
                  class="labeled-select-label-text"
                >
                  Scale Family
                </span>
                <div
                  class="labeled-select-field"
                >
                  <select
                    class="labeled-select-native"
                    id="_r_m_"
                  >
                    <option
                      value="Major Modes"
                    >
                      Major Modes
                    </option>
                    <option
                      value="Harmonic Minor"
                    >
                      Harmonic Minor
                    </option>
                    <option
                      value="Melodic Minor"
                    >
                      Melodic Minor
                    </option>
                    <option
                      value="Pentatonic"
                    >
                      Pentatonic
                    </option>
                    <option
                      value="Blues"
                    >
                      Blues
                    </option>
                  </select>
                  <span
                    aria-hidden="true"
                    class="labeled-select-chevron"
                  >
                    ▾
                  </span>
                </div>
              </label>
            </div>
          </div>
          <div
            class="control-section"
          >
            <div
              class="theory-mode-browser panel-surface panel-surface--compact"
            >
              <span
                class="section-label"
              >
                Mode
              </span>
              <div
                aria-label="Browse Mode"
                class="theory-browser-main"
                role="group"
              >
                <button
                  aria-label="Previous Mode"
                  class="theory-nav-btn"
                  type="button"
                >
                  <svg
                    aria-hidden="true"
                    class="lucide lucide-chevron-left"
                    fill="none"
                    height="16"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="16"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="m15 18-6-6 6-6"
                    />
                  </svg>
                </button>
                <div
                  class="theory-browser-selector"
                >
                  <div
                    class="labeled-select labeled-select--hide-label"
                  >
                    <label
                      class="labeled-select-label"
                      for="_r_n_"
                    >
                      <span
                        class="labeled-select-label-text"
                      >
                        Mode
                      </span>
                      <div
                        class="labeled-select-field"
                      >
                        <select
                          class="labeled-select-native"
                          id="_r_n_"
                        >
                          <option
                            value="C Major (Ionian)"
                          >
                            C Major (Ionian)
                          </option>
                          <option
                            value="C Dorian"
                          >
                            C Dorian
                          </option>
                          <option
                            value="C Phrygian"
                          >
                            C Phrygian
                          </option>
                          <option
                            value="C Lydian"
                          >
                            C Lydian
                          </option>
                          <option
                            value="C Mixolydian"
                          >
                            C Mixolydian
                          </option>
                          <option
                            value="C Natural Minor (Aeolian)"
                          >
                            C Natural Minor (Aeolian)
                          </option>
                          <option
                            value="C Locrian"
                          >
                            C Locrian
                          </option>
                        </select>
                        <span
                          aria-hidden="true"
                          class="labeled-select-chevron"
                        >
                          ▾
                        </span>
                      </div>
                    </label>
                  </div>
                </div>
                <button
                  aria-label="Next Mode"
                  class="theory-nav-btn"
                  type="button"
                >
                  <svg
                    aria-hidden="true"
                    class="lucide lucide-chevron-right"
                    fill="none"
                    height="16"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="16"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="m9 18 6-6-6-6"
                    />
                  </svg>
                </button>
              </div>
              <div
                class="toggle-group toggle-group--default"
                role="group"
              >
                <button
                  aria-pressed="true"
                  class="toggle-btn active"
                  type="button"
                >
                  Parallel
                </button>
                <button
                  aria-pressed="false"
                  class="toggle-btn"
                  type="button"
                >
                  Relative
                </button>
              </div>
            </div>
          </div>
          <div
            class="theory-inline-key panel-surface panel-surface--compact"
          >
            <button
              aria-expanded="false"
              class="theory-disclosure-btn"
              type="button"
            >
              <span
                class="theory-disclosure-title"
              >
