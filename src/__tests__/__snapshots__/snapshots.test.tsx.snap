                    id="fretboard-_r_p_-fretboard-wood"
                    x1="0"
                    x2="0"
                    y1="0"
                    y2="1"
                  >
                    <stop
                      offset="0%"
                      stop-color="var(--fretboard-wood-top)"
                    />
                    <stop
                      offset="55%"
                      stop-color="#0d0805"
                    />
                    <stop
                      offset="100%"
                      stop-color="var(--fretboard-wood-bottom)"
                    />
                  </lineargradient>
                  <lineargradient
                    id="fretboard-_r_p_-fretboard-vignette"
                    x1="0"
                    x2="1"
                    y1="0"
                    y2="0"
                  >
