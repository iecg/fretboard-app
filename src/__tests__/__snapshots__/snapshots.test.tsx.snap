exports[`Component Snapshots > App layout snapshots > renders with chord overlay snapshot > app-with-chord-overlay 1`] = `
<div>
  <div
    class="app-container"
    data-layout-mode="desktop-expanded"
  >
    <header
      class="app-header"
    >
      <div
        class="logo-container"
      >
        <div
          class="logo-icon"
        >
          <svg
            aria-hidden="true"
            class="lucide lucide-music icon"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M9 18V5l12-2v13"
            />
            <circle
              cx="6"
              cy="18"
              r="3"
            />
            <circle
              cx="18"
              cy="16"
              r="3"
            />
          </svg>
        </div>
        <div
          class="title-container"
        >
          <h1>
            FretFlow
          </h1>
          <p>
            Interactive Fretboard & Music Theory
          </p>
        </div>
      </div>
      <div
        class="header-actions"
      >
        <a
          class="kofi-header-btn"
          href="https://ko-fi.com/E1E01XFJ0G"
          rel="noopener noreferrer"
          target="_blank"
          title="Support FretFlow on Ko-fi"
        >
          <img
            alt="Support me on Ko-fi"
            class="kofi-btn-desktop"
            src="https://storage.ko-fi.com/cdn/brandasset/v2/support_me_on_kofi_blue.png"
          />
          <img
            alt="Ko-fi"
            class="kofi-btn-mobile"
            src="https://storage.ko-fi.com/cdn/brandasset/v2/kofi_symbol.png"
          />
        </a>
        <button
          aria-label="Open settings"
          class="header-btn"
          title="Settings"
        >
          <svg
            aria-hidden="true"
            class="lucide lucide-settings2 lucide-settings-2 icon"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M14 17H5"
            />
            <path
              d="M19 7h-9"
            />
            <circle
              cx="17"
              cy="17"
              r="3"
            />
            <circle
              cx="7"
              cy="7"
              r="3"
            />
          </svg>
        </button>
        <button
          class="header-btn"
          title="Mute"
        >
          <svg
            aria-hidden="true"
            class="lucide lucide-volume2 lucide-volume-2 icon icon-active"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M11 4.702a.705.705 0 0 0-1.203-.498L6.413 7.587A1.4 1.4 0 0 1 5.416 8H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h2.416a1.4 1.4 0 0 1 .997.413l3.383 3.384A.705.705 0 0 0 11 19.298z"
            />
            <path
              d="M16 9a5 5 0 0 1 0 6"
            />
            <path
              d="M19.364 18.364a9 9 0 0 0 0-12.728"
            />
          </svg>
        </button>
      </div>
    </header>
    <main
      class="main-fretboard"
    >
      <div
        class="fretboard-outer"
      >
        <div
          class="fretboard-toolbar"
        >
          <div
            class="viewport-jumps"
          >
            <span
              class="section-label"
            >
              Go to
            </span>
            <button
              class="toolbar-btn"
            >
              Open
            </button>
            <button
              class="toolbar-btn"
            >
              Mid
            </button>
            <button
              class="toolbar-btn"
            >
              High
            </button>
          </div>
        </div>
        <div
          class="fretboard-wrapper hide-scrollbar"
          style="cursor: default;"
        >
