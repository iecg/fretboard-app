        aria-label="Guitar fretboard — C"
        class="fretboard-board"
        role="group"
      >
        <div
          class="fretboard-neck"
          style="height: 216px; width: 1225px; --string-row-px: 36px; --glow-cyan: url(#fretboard-_r_0_-glow-cyan); --glow-orange: url(#fretboard-_r_0_-glow-orange); --glow-violet: url(#fretboard-_r_0_-glow-violet);"
        >
          <svg
            aria-hidden="true"
            class="fretboard-main-svg"
            height="216"
            style="display: block; position: absolute; top: 0px; left: 0px;"
            width="1225"
          >
            <defs>
              <lineargradient
                id="fretboard-_r_0_-fretboard-wood"
                x1="0"
                x2="0"
                y1="0"
                y2="1"
              >
                <stop
                  offset="0%"
                  stop-color="var(--fretboard-wood-top)"
                />
                <stop
                  offset="55%"
                  stop-color="#0d0805"
                />
                <stop
                  offset="100%"
                  stop-color="var(--fretboard-wood-bottom)"
                />
              </lineargradient>
              <lineargradient
                id="fretboard-_r_0_-fretboard-vignette"
                x1="0"
                x2="1"
                y1="0"
                y2="0"
              >
                <stop
