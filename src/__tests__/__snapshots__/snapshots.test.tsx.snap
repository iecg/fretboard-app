              aria-pressed="false"
              class="degree-chip"
              type="button"
            >
              <span
                class="degree-chip-note"
              >
                B
              </span>
            </button>
            <span
              class="degree-chip-interval"
            >
              7
            </span>
          </li>
        </ul>
      </section>
