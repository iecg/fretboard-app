          <svg
            aria-hidden="true"
            class="lucide lucide-settings2 lucide-settings-2 icon"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
