{
  "name": "fretboard-app",
  "private": true,
  "version": "2.3.0",
  "type": "module",
  "main": "./packages/core/dist/index.js",
  "types": "./packages/core/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/core/dist/index.d.ts",
      "default": "./packages/core/dist/index.js"
    }
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @fretflow/core run build && tsc -b && vite build",
    "build:mobile": "VITE_MOBILE=true pnpm run build",
    "build:types": "pnpm --filter @fretflow/core run build && tsc -b",
    "lint": "eslint . && stylelint 'src/**/*.css'",
    "preview": "vite preview",
    "preview:prod": "pnpm run build && vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:production": "pnpm run build && playwright test --config=playwright.config.production.ts",
    "test:e2e:css-scoping": "pnpm run test:e2e:production -- e2e/css-scoping.spec.ts",
    "test:visual": "pnpm run build && playwright test --config=playwright.config.visual.ts",
    "test:visual:ci": "bash scripts/run-linux-visual-tests.sh",
    "test:visual:update": "pnpm run build && playwright test --config=playwright.config.visual.ts --update-snapshots",
    "test:visual:update:linux": "bash scripts/update-linux-snapshots.sh",
    "prepare": "pnpm --filter @fretflow/core run build && husky",
    "analyze": "source-map-explorer dist/assets/*.js --html dist/bundle-report.html"
  },
  "dependencies": {
    "@fretflow/core": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jotai": "^2.20.0",
    "lucide-react": "^1.14.0",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.6",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "playwright": "^1.60.0",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended": "^18.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.css": "stylelint --fix"
  }
}
