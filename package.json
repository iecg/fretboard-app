{
  "name": "fretboard-app",
  "private": true,
  "version": "2.13.0",
  "type": "module",
  "main": "./packages/core/dist/index.js",
  "types": "./packages/core/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/core/dist/index.d.ts",
      "default": "./packages/core/dist/index.js"
    }
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @fretflow/core run build && tsc -b && vite build && cp dist/index.html dist/404.html",
    "build:types": "pnpm --filter @fretflow/core run build && tsc -b",
    "lint": "eslint . && node scripts/check-fretboard-boundaries.mjs",
    "ui:tokens": "node scripts/ui-tokens.mjs",
    "preview": "vite preview",
    "preview:prod": "pnpm run build && vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:production": "pnpm run build && playwright test --config=playwright.config.production.ts",
    "test:e2e:css-scoping": "pnpm run test:e2e:production -- e2e/css-scoping.spec.ts",
    "test:visual": "pnpm run build && playwright test --config=playwright.config.visual.ts",
    "test:visual:ci": "bash scripts/run-linux-visual-tests.sh",
    "test:visual:update": "pnpm run build && playwright test --config=playwright.config.visual.ts --update-snapshots",
    "test:visual:update:linux": "bash scripts/update-linux-snapshots.sh",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null; pnpm --filter @fretflow/core run build",
    "analyze": "source-map-explorer dist/assets/*.js --html dist/bundle-report.html"
  },
  "dependencies": {
    "@fretflow/core": "workspace:*",
    "@fretflow/fretboard": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "clsx": "^2.1.1",
    "jotai": "2.20.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tone": "^15.1.22",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "culori": "^4.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "source-map-explorer": "^2.5.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.1.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "vitest-axe": "^0.1.0"
  }
}
